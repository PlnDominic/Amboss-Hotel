# Password for /admin/bookings. Set a real value in production — the code
# falls back to a well-known default ("anboss-admin") if this is unset.
ADMIN_PASSWORD=change-me

# Gmail credentials used to email new bookings. GMAIL_APP_PASSWORD must be a
# 16-character Gmail App Password (Google Account -> Security -> 2-Step
# Verification -> App passwords), not your regular Gmail password — Google
# does not allow regular-password SMTP login. Booking emails are silently
# skipped (with a console warning) if these are not set.
GMAIL_USER=your-address@gmail.com
GMAIL_APP_PASSWORD=your-16-character-app-password

# Optional: where booking notification emails are sent. Defaults to
# GMAIL_USER if unset.
BOOKING_NOTIFICATION_EMAIL=your-address@gmail.com
